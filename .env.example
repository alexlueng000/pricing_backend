APP_NAME=Patent Quote System
APP_ENV=local
SECRET_KEY=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Option 1: set the complete SQLAlchemy database URL directly.
# DATABASE_URL=mysql+pymysql://root:123456@127.0.0.1:3306/pricing?charset=utf8mb4

# Option 2: set MySQL parts and let the backend build DATABASE_URL.
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=pricing
MYSQL_USER=root
MYSQL_PASSWORD=123456

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
